{
  "expo": {
    "name": "Sonix",
    "slug": "sonix-app",
    "owner": "heythem.16",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "sonix-app",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sonix.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera access for Sonix stories and posts",
        "NSPhotoLibraryUsageDescription": "Allow photo access for Sonix stories and posts"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D0D1A"
      },
      "package": "com.sonix.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Sonix to access your camera for stories and posts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Sonix to access your photos for stories and posts."
        }
      ],
      "expo-video",
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Sonix to access your photos for stories and posts.",
          "savePhotosPermission": "Allow Sonix to save photos to your library."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d761153f-6215-4e06-a8b5-9eb78029dd6f"
      }
    }
  }
}
